# ============================================================
# Student Connect — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ============================================================

# -----------------------------------------------
# MongoDB (required)
# Get your connection string from MongoDB Atlas:
# https://cloud.mongodb.com → Connect → Drivers
# -----------------------------------------------
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=Sync

# -----------------------------------------------
# Email Service — for sync notification emails
# Use a Gmail App Password (not your regular password):
# https://myaccount.google.com/apppasswords
# -----------------------------------------------
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# -----------------------------------------------
# Todoist OAuth App Credentials
# Create an app at: https://developer.todoist.com/appconsole.html
# Set the redirect URI to: https://localhost:5000/api/todist-api-link
# -----------------------------------------------
TODOIST_CLIENT_ID=your_todoist_client_id
TODOIST_CLIENT_SECRET=your_todoist_client_secret

# -----------------------------------------------
# Notion OAuth App Credentials
# Create an integration at: https://www.notion.so/my-integrations
# Set the redirect URI to: https://localhost:5000/api/notion-api-link
# -----------------------------------------------
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret

# -----------------------------------------------
# Auto-generated on first run — DO NOT set manually.
# These will be appended to your .env automatically
# by the Flask app on startup.
# -----------------------------------------------
# JWT_SECRET_KEY=
# PRIVATE_PASS=
