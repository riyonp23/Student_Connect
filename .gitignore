# ============================================================
# Student Connect — .gitignore
# Covers: Python/Flask, Node/React/Vite, secrets, certificates
# ============================================================

# -----------------------------------------------
# 🔴 CRITICAL: SECRETS — NEVER COMMIT THESE
# -----------------------------------------------
.env
.env.*
!.env.example          # Allow the example template

# RSA Key Pairs (auto-generated on first run)
backend/src/private_key.pem
backend/src/public_key.pem

# TLS/HTTPS Dev Certificates (generated by mkcert)
backend/src/*.pem
frontend/src/Certs/*.pem

# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebooks
.ipynb_checkpoints

# -----------------------------------------------
# Flask / Backend
# -----------------------------------------------
instance/
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# Flask session
flask_session/

# -----------------------------------------------
# Node / React / Vite
# -----------------------------------------------
node_modules/
dist/
.cache/
.parcel-cache/

# Vite
frontend/dist/
frontend/.vite/

# Build output
frontend/build/

# -----------------------------------------------
# Temp / scratch files (clean up before pushing)
# -----------------------------------------------
*.txt
!README.txt           # Allow README if needed
backend/test.py
backend/test*.py
backend/all_courses.json
frontend/src/canvas.txt
frontend/src/placeholder.txt
frontend/src/temp.txt

# Backup / duplicate files
*copy*
*Copy*
* copy.*

# -----------------------------------------------
# OS / Editor
# -----------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V4
.Trashes
ehthumbs.db
Thumbs.db

# Windows
desktop.ini

# VS Code
.vscode/
*.code-workspace

# JetBrains / PyCharm
.idea/
*.iml
*.iws

# -----------------------------------------------
# Misc
# -----------------------------------------------
*.bak
*.swp
*.swo
db.json
